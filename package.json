{
  "name": "@rodbe/ghx",
  "version": "1.8.0",
  "description": "Clone GitHub repositories with a friendly CLI",
  "keywords": [
    "front-end",
    "RBX",
    "typescript",
    "cli",
    "cli-app",
    "cli-tool",
    "unix",
    "GitHub"
  ],
  "homepage": "https://github.com/rodbe-io/ghx",
  "bugs": {
    "url": "https://github.com/rodbe-io/ghx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodbe-io/ghx.git"
  },
  "license": "MIT",
  "author": "KevinRodbe",
  "type": "module",
  "bin": {
    "ghx": "./dist/commands/ghx.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm run type-check",
    "build": "pkgroll",
    "commit": "git-cz",
    "commitlint": "commitlint --edit",
    "eslint:fix": "eslint --fix",
    "prepare": "husky || true",
    "release": "semantic-release",
    "start": "pkgroll --watch",
    "test:unit": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "dependencies": {
    "@inquirer/input": "^5.1.2",
    "@inquirer/select": "^4.4.2",
    "@rodbe/check-updates": "^1.4.0",
    "@rodbe/fn-utils": "^1.13.0",
    "@rodbe/get-config": "^1.0.1",
    "@rodbe/github-api": "^2.4.0",
    "chalk": "^5.6.2",
    "inquirer-select-pro": "1.0.0-alpha.9",
    "yargs": "^17.7.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "@commitlint/format": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@eslint/json": "^0.10.0",
    "@rodbe/prettier-config": "^1.5.0",
    "@rodbe/tsconfig": "^1.5.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/npm": "13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.20.0",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^3.2.6",
    "commitizen": "^4.3.2",
    "conventional-changelog-conventionalcommits": "5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "nano-staged": "^0.8.0",
    "pkgroll": "^2.27.1",
    "prettier": "^3.9.4",
    "prettier-plugin-curly": "^0.3.2",
    "prettier-plugin-packagejson": "^2.5.22",
    "semantic-release": "25.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">= 18.18.2",
    "npm": ">= 8.11.0",
    "pnpm": ">= 10.5.2"
  },
  "volta": {
    "node": "25.2.1",
    "pnpm": "10.5.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "@eslint/plugin-kit@<0.3.4": ">=0.3.4"
    }
  },
  "enginesStrict": true
}
